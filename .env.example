# Supabase project credentials (public, build-time). Safe to expose because Row Level
# Security restricts access to the authenticated user's own rows. Copy to .env.local for
# local dev; in CI these come from GitHub Actions repository secrets.
# The service_role key must NEVER go here or anywhere in this repo.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
